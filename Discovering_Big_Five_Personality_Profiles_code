def is_english(text_val):
    if not isinstance(text_val, str):
        return False
    # Quick pre-filter: skip if the string is too short or lacks alphabetic characters
    cleaned_temp = re.sub(r'[^a-zA-Z\s]', '', text_val).strip()
    if len(cleaned_temp) < 10:
         return False
    try:
        # Detect primary language
        return detect(text_val) == 'en'
    except Exception:
        # Gracefully reject posts that cause detection errors (e.g. pure links, punctuation)
        return False

print("Filtering for English-only posts...")
# Use progress_apply to display progress bar during language detection
df_clean['is_en'] = df_clean['STATUS'].progress_apply(is_english)
