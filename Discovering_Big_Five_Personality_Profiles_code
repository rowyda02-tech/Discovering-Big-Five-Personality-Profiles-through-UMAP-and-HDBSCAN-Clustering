# 3. TEXT PRE-PROCESSING
def clean_text_for_embedding(text_val):
    if not isinstance(text_val, str):
        return ""
    # Convert emojis to text labels
    text_val = emoji.demojize(text_val, delimiters=(" ", " "))
    text_val = text_val.replace("_", " ").replace(":", "")
    text_val = text_val.lower()
    # Remove URLs, HTML, and mentions
    text_val = re.sub(r'http\S+|www\.\S+', '', text_val)
    text_val = re.sub(r'<.*?>', '', text_val)
    text_val = re.sub(r'@\w+', '', text_val)
    # Remove extra spaces
    text_val = re.sub(r'\s+', ' ', text_val).strip()
    return text_val

df_clean['clean_status'] = df_clean['STATUS'].apply(clean_text_for_embedding)
# Filter out empty or extremely short updates
df_clean = df_clean[df_clean['clean_status'].str.len() > 5].reset_index(drop=True)

# 2. PSYCHOMETRIC STANDARDIZATION (True Baseline Z-Scores)
personality_cols = ['sOPN', 'sCON', 'sEXT', 'sAGR', 'sNEU']
personality_labels = ['Openness', 'Conscientiousness', 'Extraversion', 'Agreeableness', 'Neuroticism']

### STANDARD SCALER
# Initialize StandardScaler
scaler = StandardScaler()

# Step A: Identify unique users to compute baseline population statistics
unique_users = df_clean.drop_duplicates(subset=['#AUTHID'])

# Step B: Fit the scaler on unique users to avoid user-activity bias
scaler.fit(unique_users[personality_cols])

# Step C: Scale the main dataframe (adds columns with '_scaled' suffix)
