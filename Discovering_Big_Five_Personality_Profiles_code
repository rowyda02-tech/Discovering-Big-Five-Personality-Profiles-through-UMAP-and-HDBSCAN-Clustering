    weakest_val = scaled_scores.min()

    sample_posts = clustered_only[clustered_only['cluster'] == cluster_id]['STATUS'].sample(n=3, random_state=42).tolist()

    print(f"ð CONTENT ARCHETYPE: CLUSTER {cluster_id}")
    print(f"  Keywords:  {', '.join(top_words)}")
