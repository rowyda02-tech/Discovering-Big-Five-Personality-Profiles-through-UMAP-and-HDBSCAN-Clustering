# 4. SBERT EMBEDDINGS (Post-Level)
print("Encoding status updates with SentenceTransformer...")
model = SentenceTransformer('all-MiniLM-L6-v2')
# Generate embeddings directly for individual posts
embeddings = model.encode(df_clean['clean_status'].tolist(), show_progress_bar=True)

# 5. DIMENSIONALITY REDUCTION & CLUSTERING (UMAP + HDBSCAN)
# We reduce to 5 dimensions for HDBSCAN clustering to preserve topological detail,
# and a separate 2D projection strictly for visualization.

print("Running UMAP dimensionality reduction...")
# Moderate-dimensional reduction for clustering
reducer_5d = umap.UMAP(
    n_neighbors=15,
    n_components=5,
    metric='cosine',
    random_state=42
)
embeddings_5d = reducer_5d.fit_transform(embeddings)

grid = {
    'min_cluster_size': [30, 50, 80],
    'min_samples': [25, 35, 45],
    'cluster_selection_epsilon': [0.0, 0.05, 0.1],
    'cluster_selection_method': ['eom', 'leaf']
}

keys, values = zip(*grid.items())
experiments = [dict(zip(keys, v)) for v in itertools.product(*values)]
results = []

print(f"Running Grid Search with {len(experiments)} configurations...")

for params in tqdm(experiments, desc="Optimizing HDBSCAN"):
    clusterer = hdbscan.HDBSCAN(
        min_cluster_size=params['min_cluster_size'],
        min_samples=params['min_samples'],
        cluster_selection_epsilon=params['cluster_selection_epsilon'],
        cluster_selection_method=params['cluster_selection_method'],
        metric='euclidean'
    )
    labels = clusterer.fit_predict(embeddings_5d)

    num_clusters = len(set(labels)) - (1 if -1 in labels else 0)
    noise_pct = (labels == -1).sum() / len(labels) * 100

    clustered_mask = labels != -1

    sil = np.nan # Initialize silhouette score to NaN
    db = np.nan  # Initialize davies bouldin score to NaN

    # Calculate silhouette and davies_bouldin only if valid criteria are met
    # Need at least 2 clusters (excluding noise) and some clustered points for scoring
    if num_clusters >= 2 and clustered_mask.any():
        # Keep the original range constraint for when scores are actually calculated
        if num_clusters >= 3 and num_clusters <= 12:
            sil = silhouette_score(embeddings_5d[clustered_mask], labels[clustered_mask])
            db = davies_bouldin_score(embeddings_5d[clustered_mask], labels[clustered_mask])

    results.append({
        'min_cluster_size': params['min_cluster_size'],
        'min_samples': params['min_samples'],
        'cluster_selection_epsilon':params['cluster_selection_epsilon'],
        'cluster_selection_method': params['cluster_selection_method'],
        'num_clusters': num_clusters,
        'noise_pct': noise_pct,
        'silhouette': sil,
        'davies_bouldin': db
    })

df_results = pd.DataFrame(results)

# Filter criteria: keep noise level below 45% to find representative clusters
valid_results = df_results[df_results['noise_pct'] < 45.0]

if not valid_results.empty:
    best_config = valid_results.sort_values(by='silhouette', ascending=False).iloc[0]
else:
    # Fallback if noise filter was too restrictive or no valid silhouette scores were computed
    best_config = df_results.sort_values(by='silhouette', ascending=False, na_position='last').iloc[0]

print("\nBest Selected Configuration:")
print(best_config)

# Run final clustering with optimized parameters
best_clusterer = hdbscan.HDBSCAN(
    min_cluster_size=int(best_config['min_cluster_size']),
    min_samples=int(best_config['min_samples']),
    cluster_selection_epsilon=float(best_config['cluster_selection_epsilon']),
    cluster_selection_method=best_config['cluster_selection_method'],
    metric='euclidean'
)
df_clean['cluster'] = best_clusterer.fit_predict(embeddings_5d)

